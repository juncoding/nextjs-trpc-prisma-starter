// prisma/schema.prisma
//
// Starter schema. Add models per business domain.
// Naming: PascalCase model names, snake_case @@map for tables, camelCase fields, snake_case @map for columns.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "{{DB_PROVIDER}}"
  url      = env("DATABASE_URL")
}

// ─── Example model — delete after your first real model lands ──────────────

model Example {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  @@map("examples")
}

